{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch", "lockfileUpdate"],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "rebase",
      "platformAutomerge": true
    }
  ]
}
