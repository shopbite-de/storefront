{
  "extends": "./.nuxt/tsconfig.json",
  "include": [
    ".nuxt/nuxt.d.ts",
    ".nuxt/nuxt.node.d.ts",
    "app/**/*",
    "server/**/*",
    "shared/**/*",
    "modules/**/*",
    "layers/**/*",
    "test/**/*",
    "tests/**/*",
    "*.d.ts",
    "nuxt.config.*",
    ".config/nuxt.*",
    "content.config.*"
  ],
  "exclude": [
    "node_modules",
  ],
  "compilerOptions": {
    "typeRoots": ["./api-types", "./node_modules/@types", "./node_modules"]
  }
}
